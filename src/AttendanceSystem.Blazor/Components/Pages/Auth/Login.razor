@page "/login"
@layout AuthLayout
@inject AuthService Auth
@inject NavigationManager Navigation

<div class="login-wrapper">
    <div class="login-container">
        <div class="login-card">
            <div class="login-header">
                <div class="login-logo">◆</div>
                <h1>AttendIQ</h1>
                <p class="subtitle">Smart Attendance System</p>
            </div>

            @if (!string.IsNullOrWhiteSpace(error))
            {
                <div class="alert alert-danger mb-4" role="alert">
                    <span style="font-weight: 600">⚠ Login Failed</span>
                    <p style="margin:8px 0 0 0; font-size:0.9em">@error</p>
                </div>
            }

            <form @onsubmit="LoginAsync" @onsubmit:preventDefault>
                <div class="form-group mb-3">
                    <label for="email" class="form-label">Email Address</label>
                    <input type="email" 
                           class="form-control" 
                           id="email"
                           @bind="email" 
                           placeholder="your.email@gmail.com"
                           autocomplete="username" 
                           required />
                    <small class="form-text">Use your Gmail or corporate email</small>
                </div>

                <div class="form-group mb-2">
                    <label for="password" class="form-label">Password</label>
                    <input type="password" 
                           class="form-control" 
                           id="password"
                           @bind="password" 
                           placeholder="••••••••"
                           autocomplete="current-password" 
                           required />
                    <small class="form-text">Use your Gmail password</small>
                </div>

                <div class="mb-4" style="text-align: right">
                    <a href="/forgot-password" class="link-secondary" style="font-size: 0.9em">Forgot password?</a>
                </div>

                <button type="submit" 
                        class="btn btn-primary btn-lg w-100" 
                        disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span>
                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                            Signing in...
                        </span>
                    }
                    else
                    {
                        <span>Sign In</span>
                    }
                </button>
            </form>

            <div class="login-footer mt-4">
                <p style="text-align: center; color: var(--clr-muted); font-size: 0.85em">
                    © 2026 Attendance System. All rights reserved.
                </p>
            </div>
        </div>
    </div>
</div>

<style>
.login-wrapper {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--clr-primary) 0%, var(--clr-primary-dark) 100%);
    padding: 20px;
}

.login-container {
    width: 100%;
    max-width: 420px;
}

.login-card {
    background: white;
    border-radius: 12px;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.15);
    padding: 48px 32px;
}

.login-header {
    text-align: center;
    margin-bottom: 32px;
}

.login-logo {
    font-size: 48px;
    margin-bottom: 12px;
}

.login-header h1 {
    margin: 0;
    font-size: 28px;
    font-weight: 700;
    color: var(--clr-text);
}

.login-header .subtitle {
    margin: 8px 0 0 0;
    color: var(--clr-muted);
    font-size: 14px;
}

.form-group label {
    font-weight: 600;
    margin-bottom: 8px;
    display: block;
    color: var(--clr-text);
}

.form-control {
    padding: 10px 12px;
    border: 1px solid #ddd;
    border-radius: 6px;
    font-size: 14px;
    transition: all 0.2s;
}

.form-control:focus {
    border-color: var(--clr-primary);
    outline: none;
    box-shadow: 0 0 0 3px rgba(var(--clr-primary-rgb), 0.1);
}

.form-text {
    display: block;
    margin-top: 4px;
    color: var(--clr-muted);
    font-size: 12px;
}

.btn-lg {
    padding: 12px 24px;
    font-weight: 600;
    font-size: 15px;
    border-radius: 6px;
    transition: all 0.2s;
}

.btn-lg:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(var(--clr-primary-rgb), 0.3);
}

.link-secondary {
    color: var(--clr-primary);
    text-decoration: none;
    transition: opacity 0.2s;
}

.link-secondary:hover {
    opacity: 0.8;
}

.alert {
    padding: 12px 16px;
    border-radius: 6px;
    background: #fee;
    border-left: 4px solid #c33;
}

.spinner-border-sm {
    width: 14px;
    height: 14px;
}

@* @media (max-width: 480px) {
    .login-card {
        padding: 32px 24px;
    } *@
    
    .login-header h1 {
        font-size: 24px;
    }
}
</style>

@code {
    private string email = string.Empty;
    private string password = string.Empty;
    private bool isLoading;
    private string? error;

    protected override async Task OnInitializedAsync()
    {
        // Pre-fill with example Gmail if needed
    }

    private async Task LoginAsync()
    {
        try
        {
            isLoading = true;
            error = null;

            if (string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(password))
            {
                error = "Email and password are required.";
                return;
            }

            if (!email.Contains("@"))
            {
                error = "Please enter a valid email address.";
                return;
            }

            var result = await Auth.LoginAsync(email, password);
            if (!result.Success)
            {
                error = result.Error ?? "Login failed. Please check your credentials.";
                return;
            }

            Navigation.NavigateTo(result.TargetPath, replace: true);
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }
}
