@page "/login"
@layout AuthLayout
@inject AuthService Auth
@inject NavigationManager Navigation
@inject HttpClient Http
@using System.Net.Http.Json

<div class="login-wrapper">
    <div class="flip-container">
        <div class="flip-card @(showForgot ? "flipped" : "")">

            <div class="flip-front login-card">
                <div class="login-header">
                    <div class="login-logo">◆</div>
                    <h1>AttendIQ</h1>
                    <p class="subtitle">Smart Attendance System</p>
                </div>

                @if (!string.IsNullOrWhiteSpace(error))
                {
                    <div class="alert alert-danger mb-4" role="alert">
                        <span style="font-weight: 600">⚠ Login Failed</span>
                        <p style="margin:8px 0 0 0; font-size:0.9em">@error</p>
                    </div>
                }

                <form @onsubmit="LoginAsync" @onsubmit:preventDefault>
                    <div class="form-group mb-3">
                        <label for="email" class="form-label">Email Address</label>
                        <input type="email" class="form-control" id="email"
                               @bind="email" placeholder="your.email@gmail.com"
                               autocomplete="username" required />
                    </div>

                    <div class="form-group mb-2">
                        <label for="password" class="form-label">Password</label>
                        <input type="password" class="form-control" id="password"
                               @bind="password" placeholder="••••••••"
                               autocomplete="current-password" required />
                    </div>

                    <div class="mb-4" style="text-align: right">
                        <a href="#" class="link-secondary" style="font-size: 0.9em"
                           @onclick="ShowForgot" @onclick:preventDefault>Forgot password?</a>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg w-100" disabled="@isLoading">
                        @if (isLoading)
                        {
                            <span><span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Signing in...</span>
                        }
                        else
                        {
                            <span>Sign In</span>
                        }
                    </button>
                </form>

                <div class="login-footer mt-4">
                    <p style="text-align: center; color: var(--clr-muted); font-size: 0.85em">
                        © 2026 Attendance System. All rights reserved.
                    </p>
                </div>
            </div>

            <div class="flip-back login-card">
                <div class="login-header">
                    <div class="login-logo"><i class="ti ti-lock"></i></div>
                    <h1>Reset Password</h1>
                    <p class="subtitle">Enter your email to receive a reset link</p>
                </div>

                @if (!string.IsNullOrWhiteSpace(resetMessage))
                {
                    <div class="alert alert-success mb-4">@resetMessage</div>
                }
                @if (!string.IsNullOrWhiteSpace(resetError))
                {
                    <div class="alert alert-danger mb-4">@resetError</div>
                }

                <form @onsubmit="SendResetAsync" @onsubmit:preventDefault>
                    <div class="form-group mb-4">
                        <label for="resetEmail" class="form-label">Email Address</label>
                        <input type="email" class="form-control" id="resetEmail"
                               @bind="resetEmail" placeholder="your.email@company.com" required />
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg w-100" disabled="@resetLoading">
                        @if (resetLoading)
                        {
                            <span>Sending...</span>
                        }
                        else
                        {
                            <span>Send Reset Link</span>
                        }
                    </button>

                    <div class="mt-4" style="text-align: center">
                        <a href="#" class="link-secondary" @onclick="BackToLogin" @onclick:preventDefault>
                            <i class="ti ti-arrow-left"></i> Back to Login
                        </a>
                    </div>
                </form>
            </div>

        </div>
    </div>
</div>

<style>
.login-wrapper {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--clr-primary) 0%, var(--clr-primary-dark) 100%);
    padding: 20px;
}

.flip-container {
    width: 100%;
    max-width: 420px;
    perspective: 1200px;
}

.flip-card {
    position: relative;
    width: 100%;
    min-height: 480px;
    transition: transform 0.6s;
    transform-style: preserve-3d;
}

.flip-card.flipped {
    transform: rotateY(180deg);
}

.flip-front, .flip-back {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
}

.flip-back {
    transform: rotateY(180deg);
}

.login-card {
    background: white;
    border-radius: 12px;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.15);
    padding: 48px 32px;
    box-sizing: border-box;
}

.login-header {
    text-align: center;
    margin-bottom: 32px;
}

.login-logo {
    font-size: 48px;
    margin-bottom: 12px;
}

.login-header h1 {
    margin: 0;
    font-size: 28px;
    font-weight: 700;
    color: var(--clr-text);
}

.login-header .subtitle {
    margin: 8px 0 0 0;
    color: var(--clr-muted);
    font-size: 14px;
}

.form-group label {
    font-weight: 600;
    margin-bottom: 8px;
    display: block;
    color: var(--clr-text);
}

.form-control {
    padding: 10px 12px;
    border: 1px solid #ddd;
    border-radius: 6px;
    font-size: 14px;
    transition: all 0.2s;
}

.form-control:focus {
    border-color: var(--clr-primary);
    outline: none;
    box-shadow: 0 0 0 3px rgba(var(--clr-primary-rgb), 0.1);
}

.btn-lg {
    padding: 12px 24px;
    font-weight: 600;
    font-size: 15px;
    border-radius: 6px;
    transition: all 0.2s;
}

.btn-lg:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(var(--clr-primary-rgb), 0.3);
}

.link-secondary {
    color: var(--clr-primary);
    text-decoration: none;
    transition: opacity 0.2s;
    cursor: pointer;
}

.link-secondary:hover {
    opacity: 0.8;
}

.alert {
    padding: 12px 16px;
    border-radius: 6px;
    background: #fee;
    border-left: 4px solid #c33;
}

.alert-success {
    background: #efe;
    border-left: 4px solid #3c3;
}

.spinner-border-sm {
    width: 14px;
    height: 14px;
}
</style>

@code {
    private string email = string.Empty;
    private string password = string.Empty;
    private bool isLoading;
    private string? error;

    private bool showForgot;
    private string resetEmail = string.Empty;
    private string? resetMessage;
    private string? resetError;
    private bool resetLoading;

    private async Task LoginAsync()
    {
        try
        {
            isLoading = true;
            error = null;

            if (string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(password))
            {
                error = "Email and password are required.";
                return;
            }

            if (!email.Contains("@"))
            {
                error = "Please enter a valid email address.";
                return;
            }

            var result = await Auth.LoginAsync(email, password);
            if (!result.Success)
            {
                error = result.Error ?? "Login failed. Please check your credentials.";
                return;
            }

            Navigation.NavigateTo(result.TargetPath, replace: true);
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ShowForgot()
    {
        error = null;
        resetMessage = null;
        resetError = null;
        showForgot = true;
    }

    private void BackToLogin()
    {
        showForgot = false;
    }

    private async Task SendResetAsync()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(resetEmail))
            {
                resetError = "Email is required.";
                return;
            }

            resetLoading = true;
            resetError = null;
            resetMessage = null;

            var response = await Http.PostAsJsonAsync("api/auth/forgot-password", new { Email = resetEmail });
            if (response.IsSuccessStatusCode)
            {
                resetMessage = "Check your email for password reset instructions.";
                resetEmail = string.Empty;
            }
            else
            {
                resetError = "Failed to process request. Please try again.";
            }
        }
        catch (Exception ex)
        {
            resetError = ex.Message;
        }
        finally
        {
            resetLoading = false;
        }
    }
}