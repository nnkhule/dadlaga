@page "/forgot-password"
@layout AuthLayout
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager Navigation

<div class="login-wrapper">
    <div class="login-container">
        <div class="login-card">
            <div class="login-header">
                <h1>Reset Password</h1>
                <p class="subtitle">Enter your email to receive a password reset link</p>
            </div>

            @if (!string.IsNullOrWhiteSpace(message))
            {
                <div class="alert alert-success mb-4">@message</div>
            }

            @if (!string.IsNullOrWhiteSpace(error))
            {
                <div class="alert alert-danger mb-4">@error</div>
            }

            <form @onsubmit="SubmitAsync" @onsubmit:preventDefault>
                <div class="form-group mb-4">
                    <label for="email" class="form-label">Email Address</label>
                    <input type="email"
                           class="form-control"
                           id="email"
                           @bind="email"
                           placeholder="your.email@company.com"
                           required />
                </div>

                <button type="submit"
                        class="btn btn-primary btn-lg w-100"
                        disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span>Sending...</span>
                    }
                    else
                    {
                        <span>Send Reset Link</span>
                    }
                </button>

                <div class="mt-4" style="text-align: center">
                    <a href="/login" class="link-secondary">Back to Login</a>
                </div>
            </form>
        </div>
    </div>
</div>

@code {
    private string email = string.Empty;
    private string? message;
    private string? error;
    private bool isLoading;

    private async Task SubmitAsync()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(email))
            {
                error = "Email is required.";
                return;
            }

            isLoading = true;
            error = null;
            message = null;

            var response = await Http.PostAsJsonAsync("api/auth/forgot-password", new { Email = email });
            if (response.IsSuccessStatusCode)
            {
                message = "Check your email for password reset instructions.";
                email = string.Empty;
            }
            else
            {
                error = "Failed to process request. Please try again.";
            }
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }
}
