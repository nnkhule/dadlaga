@page "/forgot-password"
@layout AuthLayout
@inject ApiClient Api

<div class="login-container">
    <div class="login-right mx-auto">
        <div class="login-card">
            <h3 class="mb-4">Forgot Password</h3>
            @if (!string.IsNullOrWhiteSpace(message)) { <div class="alert alert-info">@message</div> }
            @if (!string.IsNullOrWhiteSpace(error)) { <div class="alert alert-danger">@error</div> }
            <label class="form-label">Email</label>
            <input class="form-control mb-3" @bind="email" />
            <button class="btn btn-primary w-100" @onclick="SubmitAsync" disabled="@isLoading">Submit</button>
        </div>
    </div>
</div>

@code {
    private string email = string.Empty;
    private string? message;
    private string? error;
    private bool isLoading;

    private async Task SubmitAsync()
    {
        try
        {
            isLoading = true;
            error = null;
            var response = await Api.PostAsync("api/auth/forgot-password", new { Email = email });
            message = response.IsSuccessStatusCode ? "Password reset request submitted." : null;
            if (!response.IsSuccessStatusCode) error = await response.Content.ReadAsStringAsync();
        }
        finally
        {
            isLoading = false;
        }
    }
}
