@page "/change-password"
@inject ApiClient Api

<h3 class="mb-4">Change Password</h3>

<section class="panel form-narrow">
    @if (!string.IsNullOrWhiteSpace(message)) { <div class="alert alert-info">@message</div> }
    @if (!string.IsNullOrWhiteSpace(error)) { <div class="alert alert-danger">@error</div> }
    <input type="password" class="form-control mb-3" placeholder="Current password" @bind="currentPassword" />
    <input type="password" class="form-control mb-3" placeholder="New password" @bind="newPassword" />
    <input type="password" class="form-control mb-3" placeholder="Confirm password" @bind="confirmPassword" />
    <button class="btn btn-primary" @onclick="SubmitAsync" disabled="@isLoading">Change Password</button>
</section>

@code {
    private string currentPassword = string.Empty;
    private string newPassword = string.Empty;
    private string confirmPassword = string.Empty;
    private string? message;
    private string? error;
    private bool isLoading;

    private async Task SubmitAsync()
    {
        try
        {
            isLoading = true;
            error = null;
            var response = await Api.PostAsync("api/auth/change-password", new { CurrentPassword = currentPassword, NewPassword = newPassword, ConfirmPassword = confirmPassword });
            message = response.IsSuccessStatusCode ? "Password changed." : null;
            if (!response.IsSuccessStatusCode) error = await response.Content.ReadAsStringAsync();
        }
        finally
        {
            isLoading = false;
        }
    }
}
