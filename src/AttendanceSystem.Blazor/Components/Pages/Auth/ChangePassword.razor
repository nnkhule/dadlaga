@page "/change-password"
@attribute [Authorize]
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager Navigation

<div class="page-stack">
    <div class="page-header">
        <div class="page-header-main">
            <h1>Change Password</h1>
            <p>Update your account password</p>
        </div>
    </div>

    <div class="card" style="max-width: 500px;">
        @if (!string.IsNullOrWhiteSpace(message))
        {
            <div class="alert alert-success mb-4">
                @message
                <a href="/attendance" class="btn btn-sm btn-primary mt-2">Back to Dashboard</a>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(error))
        {
            <div class="alert alert-danger mb-4">@error</div>
        }

        @if (string.IsNullOrWhiteSpace(message))
        {
            <form @onsubmit="SubmitAsync" @onsubmit:preventDefault>
                <div class="form-group mb-3">
                    <label for="currentPassword" class="form-label">Current Password</label>
                    <input type="password"
                           class="form-control"
                           id="currentPassword"
                           @bind="currentPassword"
                           placeholder="Enter current password"
                           required />
                </div>

                <div class="form-group mb-3">
                    <label for="newPassword" class="form-label">New Password</label>
                    <input type="password"
                           class="form-control"
                           id="newPassword"
                           @bind="newPassword"
                           placeholder="••••••••"
                           required />
                    <small class="form-text">At least 8 characters with uppercase, lowercase, and numbers</small>
                </div>

                <div class="form-group mb-4">
                    <label for="confirmPassword" class="form-label">Confirm Password</label>
                    <input type="password"
                           class="form-control"
                           id="confirmPassword"
                           @bind="confirmPassword"
                           placeholder="••••••••"
                           required />
                </div>

                <div style="display: flex; gap: 12px;">
                    <button type="submit"
                            class="btn btn-primary"
                            disabled="@isLoading">
                        @if (isLoading)
                        {
                            <span>Changing...</span>
                        }
                        else
                        {
                            <span>Change Password</span>
                        }
                    </button>
                    <button type="button"
                            class="btn btn-ghost"
                            @onclick="@(() => Navigation.NavigateTo("/attendance"))">
                        Cancel
                    </button>
                </div>
            </form>
        }
    </div>
</div>

@code {
    private string currentPassword = string.Empty;
    private string newPassword = string.Empty;
    private string confirmPassword = string.Empty;
    private string? message;
    private string? error;
    private bool isLoading;

    private async Task SubmitAsync()
    {
        try
        {
            error = null;

            if (string.IsNullOrWhiteSpace(currentPassword) || string.IsNullOrWhiteSpace(newPassword) ||
                string.IsNullOrWhiteSpace(confirmPassword))
            {
                error = "All fields are required.";
                return;
            }

            if (newPassword != confirmPassword)
            {
                error = "New passwords do not match.";
                return;
            }

            if (newPassword.Length < 8)
            {
                error = "Password must be at least 8 characters.";
                return;
            }

            isLoading = true;
            var response = await Http.PostAsJsonAsync("api/auth/change-password",
                new { CurrentPassword = currentPassword, NewPassword = newPassword, ConfirmPassword = confirmPassword });

            if (response.IsSuccessStatusCode)
            {
                message = "Password changed successfully!";
                currentPassword = string.Empty;
                newPassword = string.Empty;
                confirmPassword = string.Empty;
            }
            else
            {
                var responseContent = await response.Content.ReadAsAsync<dynamic>();
                error = responseContent?.message ?? "Failed to change password.";
            }
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }
}
