@page "/reset-password"
@layout AuthLayout
@inject ApiClient Api

<div class="login-container">
    <div class="login-right mx-auto">
        <div class="login-card">
            <h3 class="mb-4">Reset Password</h3>
            @if (!string.IsNullOrWhiteSpace(message)) { <div class="alert alert-info">@message</div> }
            @if (!string.IsNullOrWhiteSpace(error)) { <div class="alert alert-danger">@error</div> }
            <input class="form-control mb-3" placeholder="Email" @bind="email" />
            <input class="form-control mb-3" placeholder="Reset token" @bind="token" />
            <input type="password" class="form-control mb-3" placeholder="New password" @bind="newPassword" />
            <input type="password" class="form-control mb-3" placeholder="Confirm password" @bind="confirmPassword" />
            <button class="btn btn-primary w-100" @onclick="SubmitAsync" disabled="@isLoading">Reset Password</button>
        </div>
    </div>
</div>

@code {
    private string email = string.Empty;
    private string token = string.Empty;
    private string newPassword = string.Empty;
    private string confirmPassword = string.Empty;
    private string? message;
    private string? error;
    private bool isLoading;

    private async Task SubmitAsync()
    {
        try
        {
            isLoading = true;
            error = null;
            var response = await Api.PostAsync("api/auth/reset-password", new { Email = email, Token = token, NewPassword = newPassword, ConfirmPassword = confirmPassword });
            message = response.IsSuccessStatusCode ? "Password reset completed." : null;
            if (!response.IsSuccessStatusCode) error = await response.Content.ReadAsStringAsync();
        }
        finally
        {
            isLoading = false;
        }
    }
}
