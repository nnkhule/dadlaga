@page "/employees"
@inject ApiClient Api
@inject NavigationManager Navigation

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="mb-0">Employees</h3>
    <button class="btn btn-primary" @onclick="CreateEmployee">Add Employee</button>
</div>

<section class="panel">
    <div class="row g-2 mb-3">
        <div class="col-md-5">
            <input class="form-control" placeholder="Search employees" @bind="search" @bind:event="oninput" />
        </div>
        <div class="col-md-auto">
            <button class="btn btn-outline-primary" @onclick="SearchAsync">Search</button>
        </div>
    </div>

    @if (isLoading)
    {
        <LoadingSpinner />
    }
    else if (!string.IsNullOrWhiteSpace(error))
    {
        <div class="alert alert-danger">@error</div>
    }
    else if (employees.Count == 0)
    {
        <div class="empty-state">No employees were found.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Employee Code</th>
                        <th>Full Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Department</th>
                        <th>Position</th>
                        <th>Hire Date</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var employee in employees)
                    {
                        <tr role="button" @onclick="() => OpenEmployee(employee.Id)">
                            <td>@employee.EmployeeCode</td>
                            <td>@employee.FullName</td>
                            <td>@employee.Email</td>
                            <td>@Display(employee.Phone)</td>
                            <td>@Display(employee.Department ?? employee.DepartmentName)</td>
                            <td>@Display(employee.Position)</td>
                            <td>@employee.HireDate</td>
                            <td><span class="@GetStatusClass(employee)">@Display(employee.Status ?? (employee.IsActive ? "Active" : "Inactive"))</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <Pagination PageNumber="@pageNumber" PageSize="@pageSize" TotalCount="@totalCount" PageChanged="ChangePageAsync" />
    }
</section>

@code {
    private IReadOnlyList<EmployeeDto> employees = [];
    private bool isLoading = true;
    private string? error;
    private string? search;
    private int pageNumber = 1;
    private int pageSize = 10;
    private int totalCount;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task SearchAsync()
    {
        pageNumber = 1;
        await LoadAsync();
    }

    private void CreateEmployee() => Navigation.NavigateTo("/employees/create");

    private void OpenEmployee(Guid id) => Navigation.NavigateTo($"/employees/{id}");

    private async Task ChangePageAsync(int page)
    {
        pageNumber = page;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            isLoading = true;
            error = null;
            var url = $"api/employees?pageNumber={pageNumber}&pageSize={pageSize}&search={Uri.EscapeDataString(search ?? string.Empty)}";
            var result = await Api.GetAsync<PagedResponse<EmployeeDto>>(url);
            employees = result?.Items ?? [];
            totalCount = result?.TotalCount ?? 0;
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private static string Display(string? value) => string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string GetStatusClass(EmployeeDto employee)
        => $"badge {(employee.IsActive ? "bg-success" : "bg-secondary")}";
}
