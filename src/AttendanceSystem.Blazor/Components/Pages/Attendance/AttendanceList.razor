@page "/attendance"
@inject ApiClient Api

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="mb-0">Attendance</h3>
    <a class="btn btn-primary" href="/attendance/checkin">GPS Check In</a>
</div>

<section class="panel mb-3">
    @if (statistics is not null)
    {
        <div class="row g-3">
            <DashboardMetric Title="Present Days" Value="@statistics.PresentDays.ToString()" />
            <DashboardMetric Title="Absent Days" Value="@statistics.AbsentDays.ToString()" />
            <DashboardMetric Title="Late Days" Value="@statistics.LateDays.ToString()" />
            <DashboardMetric Title="Attendance Rate" Value="@($"{statistics.AttendanceRate:0.##}%")" />
        </div>
    }
    else if (!isLoading)
    {
        <div class="empty-state">No attendance statistics are available.</div>
    }
</section>

<section class="panel">
    <div class="row g-2 mb-3">
        <div class="col-md-3"><input type="date" class="form-control" @bind="from" /></div>
        <div class="col-md-3"><input type="date" class="form-control" @bind="to" /></div>
        <div class="col-md-auto"><button class="btn btn-outline-primary" @onclick="LoadFirstPageAsync">Filter</button></div>
    </div>

    @if (isLoading)
    {
        <LoadingSpinner />
    }
    else if (!string.IsNullOrWhiteSpace(error))
    {
        <div class="alert alert-danger">@error</div>
    }
    else if (records.Count == 0)
    {
        <div class="empty-state">No attendance records were found.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Check In Time</th>
                        <th>Check Out Time</th>
                        <th>Work Hours</th>
                        <th>Overtime</th>
                        <th>Late Minutes</th>
                        <th>Verification Method</th>
                        <th>Attendance Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in records)
                    {
                        <tr>
                            <td>@item.Date</td>
                            <td>@FormatTime(item.CheckInTime)</td>
                            <td>@FormatTime(item.CheckOutTime)</td>
                            <td>@item.WorkHours</td>
                            <td>@(item.Overtime != 0 ? item.Overtime : item.OvertimeHours)</td>
                            <td>@item.LateMinutes</td>
                            <td>@Display(item.VerificationMethod)</td>
                            <td>@Display(item.AttendanceStatus ?? item.Status)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <Pagination PageNumber="@pageNumber" PageSize="@pageSize" TotalCount="@totalCount" PageChanged="ChangePageAsync" />
    }
</section>

@code {
    private IReadOnlyList<AttendanceDto> records = [];
    private AttendanceStatisticsDto? statistics;
    private bool isLoading = true;
    private string? error;
    private DateOnly? from;
    private DateOnly? to;
    private int pageNumber = 1;
    private int pageSize = 10;
    private int totalCount;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadFirstPageAsync()
    {
        pageNumber = 1;
        await LoadAsync();
    }

    private async Task ChangePageAsync(int page)
    {
        pageNumber = page;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            isLoading = true;
            error = null;
            var query = $"pageNumber={pageNumber}&pageSize={pageSize}&from={from:yyyy-MM-dd}&to={to:yyyy-MM-dd}";
            var history = await Api.GetAsync<PagedResponse<AttendanceDto>>($"api/attendance/history?{query}");
            records = history?.Items ?? [];
            totalCount = history?.TotalCount ?? 0;
            statistics = await Api.GetAsync<AttendanceStatisticsDto>($"api/attendance/statistics?from={from:yyyy-MM-dd}&to={to:yyyy-MM-dd}");
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private static string FormatTime(DateTime? value) => value?.ToLocalTime().ToString("HH:mm") ?? "-";
    private static string Display(string? value) => string.IsNullOrWhiteSpace(value) ? "-" : value;
}
