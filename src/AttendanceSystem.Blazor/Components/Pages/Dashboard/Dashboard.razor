@page "/dashboard"
@inject ApiClient Api

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Dashboard</h2>
    <button class="btn btn-outline-primary" @onclick="LoadAsync" disabled="@isLoading">Refresh</button>
</div>

@if (isLoading)
{
    <LoadingSpinner />
}
else if (!string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger">@error</div>
}
else if (summary is null)
{
    <div class="empty-state">No dashboard data is available.</div>
}
else
{
    <div class="row g-3">
        <DashboardMetric Title="Total Employees" Value="@summary.TotalEmployees.ToString()" />
        <DashboardMetric Title="Active Employees" Value="@summary.ActiveEmployees.ToString()" />
        <DashboardMetric Title="Present Today" Value="@summary.PresentToday.ToString()" />
        <DashboardMetric Title="Absent Today" Value="@summary.AbsentToday.ToString()" />
        <DashboardMetric Title="Late Employees" Value="@summary.LateEmployees.ToString()" />
        <DashboardMetric Title="On Leave Employees" Value="@summary.OnLeaveEmployees.ToString()" />
        <DashboardMetric Title="Attendance Rate" Value="@($"{summary.AttendanceRate:0.##}%")" />
        <DashboardMetric Title="Total Overtime Hours" Value="@($"{summary.TotalOvertimeHours:0.##}")" />
    </div>

    <div class="row g-3 mt-2">
        <div class="col-lg-7">
            <section class="panel">
                <h5>Attendance Trends</h5>
                @if (trends.Count == 0)
                {
                    <div class="empty-state">No attendance trend data is available.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Present</th>
                                    <th>Absent</th>
                                    <th>Late</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in trends)
                                {
                                    <tr>
                                        <td>@item.Date</td>
                                        <td>@item.Present</td>
                                        <td>@item.Absent</td>
                                        <td>@item.Late</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </section>
        </div>
        <div class="col-lg-5">
            <section class="panel">
                <h5>Recent Activities</h5>
                @if (activities.Count == 0)
                {
                    <div class="empty-state">No recent activities are available.</div>
                }
                else
                {
                    <div class="list-group list-group-flush">
                        @foreach (var activity in activities)
                        {
                            <div class="list-group-item px-0">
                                <div class="fw-semibold">@activity.Title</div>
                                <div class="text-muted small">@activity.Message</div>
                                <div class="text-muted small">@activity.CreatedDate.ToLocalTime()</div>
                            </div>
                        }
                    </div>
                }
            </section>
        </div>
    </div>
}

@code {
    private DashboardSummaryDto? summary;
    private IReadOnlyList<RecentActivityDto> activities = [];
    private IReadOnlyList<AttendanceTrendDto> trends = [];
    private bool isLoading = true;
    private string? error;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        try
        {
            isLoading = true;
            error = null;
            summary = await Api.GetDashboardSummaryAsync();
            activities = await Api.GetRecentActivitiesAsync() ?? [];
            trends = await Api.GetAttendanceTrendsAsync() ?? [];
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }
}
