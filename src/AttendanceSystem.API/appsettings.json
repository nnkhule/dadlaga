{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost,1433;Database=AttendanceDB;User Id=sa;Password=YourStrong@Passw0rd;TrustServerCertificate=True;",
    "Redis": "localhost:6379"
  },
  "JwtSettings": {
    "SecretKey": "CHANGE_ME_TO_A_SECURE_KEY_AT_LEAST_32_CHARS_LONG!",
    "Issuer": "AttendanceSystem",
    "Audience": "AttendanceSystemClients",
    "AccessTokenExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 30
  },
  "AttendanceRules": {
    "DefaultGraceMinutes": 10,
    "AutoGeoRadiusMeters": 100,
    "AutoGeoMinMinutes": 60,
    "MissedCheckoutAlertRadiusMeters": 200,
    "EarlyCheckinThresholdMinutes": 120,
    "SuspiciousCheckinThresholdHours": 4,
    "HalfDayLateThresholdMinutes": 180
  },
  "FaceRecognition": {
    "Provider": "CompreFace",
    "Endpoint": "http://localhost:8000",
    "ConfidenceThreshold": 0.85
  },
  "Notifications": {
    "FirebaseFcmKey": "",
    "SendGridApiKey": ""
  },
  "AI": {
    "ChatbotProvider": "Ollama",
    "OllamaEndpoint": "http://localhost:11434"
  },
  "Cors": {
    "AllowedOrigins": [ "https://localhost:7001", "http://localhost:5001", "http://127.0.0.1:5500", "http://localhost:5500" ]
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": false,
    "StackBlockedRequests": false,
    "GeneralRules": [
      {
        "Endpoint": "POST:/api/auth/login",
        "Period": "15m",
        "Limit": 100
      },
      {
        "Endpoint": "POST:/api/attendance/checkin",
        "Period": "1h",
        "Limit": 10
      }
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
